<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.undistracted.blocker</string>

	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/undistracted</string>
		<string>run</string>
	</array>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<true/>

	<key>StandardOutPath</key>
	<string>/tmp/undistracted.out</string>

	<key>StandardErrorPath</key>
	<string>/tmp/undistracted.err</string>

	<key>StartInterval</key>
	<integer>1200</integer>

	<key>UserName</key>
	<string>root</string>

	<key>GroupName</key>
	<string>wheel</string>
</dict>
</plist>
